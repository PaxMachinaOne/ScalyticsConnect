{
  "name": "Scalytics Copilot",
  "version": "1.8.0",
  "description": "Private AI and Agent System",
  "main": "server.js",
  "type": "commonjs",
  "exports": {
    ".": "./server.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "setup": "node setup/init-db.js",
    "debug": "node --inspect server.js",
    "generate-openapi-spec": "node scripts/generate-openapi-spec.js",
    "commit-check": "./scripts/commit-check.sh",
    "build:api-docs": "npm run generate-openapi-spec && npx @redocly/cli build-docs docs/openapi.json -o docs/api-docs.html",
    "deps:check": "npm outdated --depth=0 || true",
    "deps:audit": "npm audit --omit=dev || true"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "@tailwindcss/postcss": "^4.1.18",
    "axios": "1.18.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.12",
    "dotenv": "^17.4.2",
    "eventsource": "^4.1.0",
    "eventsource-parser": "^1.1.2",
    "express": "^5.2.1",
    "express-fileupload": "^1.5.2",
    "express-rate-limit": "^8.5.2",
    "franc": "^6.2.0",
    "got": "^15.1.0",
    "helmet": "^8.3.0",
    "highlight.js": "^11.11.1",
    "joi": "^18.2.3",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "marked": "^18.0.6",
    "mcp-client": "^1.13.1",
    "mermaid": "^11.16.0",
    "morgan": "^1.11.0",
    "node-fetch": "^3.3.2",
    "papaparse": "^5.5.4",
    "pdf-parse": "^2.4.5",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "react-toastify": "^11.0.5",
    "recharts": "^2.15.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mermaidjs": "^7.0.0",
    "sqlite-vec": "^0.1.7-alpha.2",
    "sqlite-vss": "^0.1.2",
    "sqlite3": "^6.0.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "tokenizers": "^0.13.3",
    "uuid": "^14.0.1",
    "web-streams-polyfill": "^4.3.0",
    "winston": "^3.19.0",
    "ws": "^8.21.1",
    "xlsx": "^0.18.5"
  },
  "optionalDependencies": {
    "tokenizers-linux-x64-gnu": "*"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "autoprefixer": "^10.5.4",
    "eslint": "^8.56.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.11",
    "postcss": "^8.5.15",
    "supertest": "^6.3.3",
    "swagger-jsdoc": "^6.3.0",
    "tailwindcss": "^4.3.2"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "private": true,
  "jest": {
    "testMatch": [
      "<rootDir>/test/**/*.test.js"
    ]
  }
}
